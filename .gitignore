## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/

# Rider
.idea/
*.sln.iml

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.mem

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/

# Files built by Visual Studio
*.obj
*.exe
*.exe.config
*.dll
*.pdb

# NuGet
*.nupkg
*.snupkg
.nuget/

# Entity Framework
*.edmx
*.edmx.diagram

# Database files
*.db
*.sqlite
*.sqlite3

# NuGet packages
.nupkg.metadata
.nupkg.props
.nuspec

# Environment files
.env
.env.local

# VS Code extensions
*.code-workspace

# macOS
.DS_Store

# Windows
Thumbs.db
