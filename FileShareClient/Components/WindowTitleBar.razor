@using FileShareClient.Services
@inject WindowControlService WindowControl

<div @onmousedown="StartDrag"
     @ondblclick="ToggleMaximize"
     style="height: 36px; background: linear-gradient(90deg, #1f2a27 0%, #2f4f46 55%, #3f6b5c 100%); color: #eef7f3; display: flex; align-items: center; justify-content: space-between; padding: 0 0 0 12px; user-select: none; border-bottom: 1px solid var(--fs-green-dark);">
    <span style="font-size: 0.85rem; font-weight: 600;">@Title</span>
    <div style="display: flex; align-items: stretch; height: 100%;">
        <button @onmousedown:stopPropagation="true"
                @onclick="Minimize"
                style="width: 46px; border: none; background: transparent; color: #eef7f3; cursor: pointer; font-size: 14px;">─</button>
        <button @onmousedown:stopPropagation="true"
                @onclick="ToggleMaximize"
                style="width: 46px; border: none; background: transparent; color: #eef7f3; cursor: pointer; font-size: 14px;">▭</button>
        <button @onmousedown:stopPropagation="true"
                @onclick="Close"
                style="width: 46px; border: none; background: var(--fs-danger); color: #fff; cursor: pointer; font-size: 14px;">✕</button>
    </div>
</div>

@code {
    [Parameter]
    public string Title { get; set; } = "FileShare";

    private void Minimize()
    {
        WindowControl.Request(WindowCommand.Minimize);
    }

    private void ToggleMaximize()
    {
        WindowControl.Request(WindowCommand.ToggleMaximize);
    }

    private void Close()
    {
        WindowControl.Request(WindowCommand.Close);
    }

    private void StartDrag()
    {
        WindowControl.Request(WindowCommand.DragMove);
    }
}
