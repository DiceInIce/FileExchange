@page "/chat"
@namespace FileShareClient.Pages
@using FileShareClient.Services
@using FileShareClient.Models
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@implements IAsyncDisposable

<div style="height: 100vh; display: flex; flex-direction: column; overflow: hidden; background: var(--fs-bg-app); color: var(--fs-text);">
    <WindowTitleBar Title="FileShare" />
    <div style="display: flex; height: calc(100vh - 36px);">
        <ChatSidebar CurrentUser="CurrentUser"
                     FilteredFriends="FilteredFriends"
                     SelectedFriend="SelectedFriend"
                     UnreadCounts="UnreadCounts"
                     FriendFilter="@FriendFilter"
                     PendingRequests="PendingRequests"
                     SearchResults="SearchResults"
                     SearchQuery="@SearchQuery"
                     Friends="Friends"
                     SentRequestUserIds="SentRequestUserIds"
                     OnLogout="Logout"
                     FriendFilterChanged="OnFriendFilterChanged"
                     SelectFriend="SelectFriend"
                     AcceptFriend="AcceptFriend"
                     RejectFriend="RejectFriend"
                     SearchQueryChanged="OnSearchQueryChanged"
                     OnPerformSearch="PerformSearch"
                     SearchItemClick="OnSearchItemClickFromSidebar"
                     SendFriendRequest="SendFriendRequest" />

        <div style="flex: 1; min-width: 0; display: flex; flex-direction: column; background: var(--fs-bg-chat); position:relative;">
            @if (ApiService.Token != null && _hubConnectionState != HubConnectionState.Connected)
            {
                <div role="status" style="flex-shrink: 0; display: flex; align-items: center; justify-content: center; gap: 14px; flex-wrap: wrap; padding: 10px 16px; background: var(--fs-danger-soft); border-bottom: 1px solid var(--fs-border); color: var(--fs-text); font-size: 0.9em;">
                    @if (_hubConnectionState == HubConnectionState.Reconnecting || _hubConnectionState == HubConnectionState.Connecting)
                    {
                        <span style="display: inline-flex; align-items: center; gap: 10px;">
                            <span class="fs-inline-spinner" aria-hidden="true"></span>
                            Восстанавливаем соединение…
                        </span>
                    }
                    else
                    {
                        <span>Нет соединения с сервером. Сообщения и звонки могут не работать.</span>
                        <button type="button" disabled="@_retryingRealtime" @onclick="RetryRealtimeConnection" class="fs-interactive fs-focusable" aria-label="Повторить подключение к серверу" style="padding: 6px 14px; background: var(--fs-green); color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 0.9em;">
                            @(_retryingRealtime ? "Подключение…" : "Повторить")
                        </button>
                    }
                </div>
            }
            @if (SelectedFriend != null)
            {
                <ChatMessageList SelectedFriend="SelectedFriend"
                                 CurrentUserId="CurrentUser?.Id"
                                 VisibleMessages="VisibleMessages"
                                 TotalMessageCount="Messages.Count"
                                 IsInitialLoading="IsInitialLoading"
                                 MessageSearchQuery="@MessageSearchQuery"
                                 MessageSearchQueryChanged="OnMessageSearchQueryChanged"
                                 ShowScrollToBottomButton="ShowScrollToBottomButton"
                                 ScrollToBottom="ScrollToBottomNow"
                                 RemoveFriend="RemoveFriend"
                                 DownloadFile="DownloadFileFromMessage" />

                <ChatComposer IsDraggingFile="IsDraggingFile"
                              MessageInput="@MessageInput"
                              MessageInputChanged="OnMessageInputChanged"
                              OnMessageKeyDown="HandleMessageKeyDown"
                              SendMessage="SendMessage"
                              IsSendingMessage="IsSendingMessage"
                              MessageDeliveryStatus="@MessageDeliveryStatus"
                              FileSendMode="@FileSendMode"
                              FileSendModeChanged="OnFileSendModeChanged"
                              FileTransferStatus="@FileTransferStatus"
                              ShowP2pChannelProgress="ShowP2pChannelProgress"
                              P2pChannelProgressIsOutgoing="P2pChannelProgressIsOutgoing"
                              P2pChannelProgressPhase="@P2pChannelProgressPhase"
                              P2pChannelProgressFileName="@P2pChannelProgressFileName"
                              P2pChannelProgress="P2pChannelProgress"
                              IsDownloading="IsDownloading"
                              DownloadIndicatorIsP2pLocal="DownloadIndicatorIsP2pLocal"
                              CurrentDownloadFileName="@CurrentDownloadFileName"
                              CurrentDownloadProgress="CurrentDownloadProgress"
                              OnFileSelected="OnFileSelected" />
            }
            else
            {
                <div style="flex: 1; display: flex; justify-content: center; align-items: center; color: var(--fs-text-faint);">
                    <div style="text-align: center;">
                        <h3>Выберите друга для начала чата</h3>
                        <p style="margin-top:8px;">Можно фильтровать друзей слева и искать по имени.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<ChatToastStack Items="Toasts" OnDismiss="DismissToast" />

@code {
    private Task OnFriendFilterChanged(string filter)
    {
        SetFriendFilter(filter);
        return Task.CompletedTask;
    }

    private Task OnSearchQueryChanged(string value)
    {
        SearchQuery = value;
        return Task.CompletedTask;
    }

    private Task OnMessageSearchQueryChanged(string value)
    {
        MessageSearchQuery = value;
        return Task.CompletedTask;
    }

    private Task OnMessageInputChanged(string value)
    {
        MessageInput = value;
        return Task.CompletedTask;
    }

    private Task OnFileSendModeChanged(string value)
    {
        FileSendMode = value;
        return Task.CompletedTask;
    }

    private Task OnSearchItemClickFromSidebar((int UserId, bool CanSendRequest) args) =>
        HandleSearchItemClick(args.UserId, args.CanSendRequest);
}
